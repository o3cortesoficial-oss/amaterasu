{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/Landpagedrone.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/Checkout(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.mjs"
    },
    {
      "source": "/Checkout - Fase 1",
      "destination": "/Checkout - Fase 1.html"
    },
    {
      "source": "/Checkout - Fase 2",
      "destination": "/Checkout - Fase 2.html"
    },
    {
      "source": "/Checkout - Fase 3",
      "destination": "/Checkout - Fase 3.html"
    },
    {
      "source": "/Checkout - Fase 4",
      "destination": "/Checkout - Fase 4.html"
    },
    {
      "source": "/Checkout - Fase 5 (page qr code)",
      "destination": "/Checkout - Fase 5 (page qr code).html"
    },
    {
      "source": "/success",
      "destination": "/success.html"
    },
    {
      "source": "/",
      "destination": "/Landpagedrone.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    }
  ]
}
